DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# Anthropic Claude API（必填，候選人面試需要）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# HR 認證 token（必填，保護所有 HR 端點）
# 產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HR_AUTH_TOKEN=

# AI kill-switch（設為 false 暫停所有 AI 功能）
# AI_ENABLED=true

# CORS 限制（生產環境請設定你的 Vercel domain）
# CORS_ORIGIN=https://your-app.vercel.app

# 公司名稱（用於寄給候選人的 email 署名）
# COMPANY_NAME=你的公司名稱

# HR 面試完成通知 email
# HR_NOTIFICATION_EMAIL=hr@company.com

# SMTP Email（可選，未設定時自動降級為複製連結）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your@gmail.com

# 前端 URL（用於 Email 中的面試連結）
# FRONTEND_URL=http://localhost:5173
